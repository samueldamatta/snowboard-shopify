{%- comment -%}
  Per-variant specification table.
  - Renders the selected (or first available) variant's specs server-side for SEO / no-JS first paint.
  - Embeds every variant's specs as JSON so JS can swap values on variant change.
  - Updates via Dawn's `PUB_SUB_EVENTS.variantChange` (assets/pubsub.js + constants.js),
    with a cross-theme `change` + `?variant=` fallback.
  Specs are stored in 8 variant metafields under the `specs` namespace.
{%- endcomment -%}

{%- liquid
  assign current = product.selected_or_first_available_variant
  assign spec_keys = 'board_type,length,flex_rating,profile,core_material,base,skill_level,terrain' | split: ','
  assign spec_labels = 'Board Type,Length,Flex Rating,Profile,Core Material,Base,Skill Level,Terrain' | split: ','
-%}

{%- style -%}
  #VariantSpecs-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #VariantSpecs-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  id="VariantSpecs-{{ section.id }}"
  class="variant-specs"
  data-vspec-section
  {{ section.shopify_attributes }}
>
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="variant-specs__eyebrow">
        <span class="variant-specs__eyebrow-text">{{ section.settings.eyebrow }}</span>
        <span class="variant-specs__eyebrow-line" aria-hidden="true"></span>
      </p>
    {%- endif -%}

    {%- if section.settings.heading != blank or section.settings.heading_accent != blank -%}
      <h2 class="variant-specs__heading">
        {{- section.settings.heading -}}
        {%- if section.settings.heading_accent != blank %} <span class="variant-specs__heading-accent">{{ section.settings.heading_accent }}</span>{% endif -%}
      </h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="variant-specs__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="variant-specs__grid">
      {%- for key in spec_keys -%}
        {%- assign label = spec_labels[forloop.index0] -%}
        {%- assign value = current.metafields.specs[key].value | default: '—' -%}
        <div class="vspec-card">
          <p class="vspec-card__label">{{ label }}</p>
          <p class="vspec-card__value" data-vspec-key="{{ key }}">{{ value }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <script type="application/json" data-vspec-data>
    {
      {%- for variant in product.variants -%}
        "{{ variant.id }}": {
          {%- for key in spec_keys -%}
            {{ key | json }}: {{ variant.metafields.specs[key].value | default: '—' | json }}{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    }
  </script>
</section>

{% javascript %}
(function () {
  function initVariantSpecs(root) {
    if (!root || root.dataset.vspecReady === 'true') return;

    var dataEl = root.querySelector('[data-vspec-data]');
    if (!dataEl) return;

    var specs;
    try {
      specs = JSON.parse(dataEl.textContent);
    } catch (error) {
      return;
    }

    var valueEls = root.querySelectorAll('[data-vspec-key]');

    function render(variantId) {
      if (variantId == null) return;
      var data = specs[variantId];
      if (!data) return;
      valueEls.forEach(function (el) {
        var value = data[el.getAttribute('data-vspec-key')];
        el.textContent = value === undefined || value === null || value === '' ? '—' : value;
      });
    }

    // Dawn-native hook: react to the theme's variant-change pub/sub event.
    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
      subscribe(PUB_SUB_EVENTS.variantChange, function (event) {
        var variant = event && event.data && event.data.variant;
        if (variant) render(variant.id);
      });
    }

    // Cross-theme fallback: read the current variant id from the cart form
    // or the ?variant= URL param after a selector changes.
    function currentVariantId() {
      try {
        var fromUrl = new URL(window.location.href).searchParams.get('variant');
        if (fromUrl) return fromUrl;
      } catch (error) {}
      var idInput = document.querySelector('form[action*="/cart/add"] [name="id"], [name="id"]');
      return idInput && idInput.value ? idInput.value : null;
    }

    document.addEventListener('change', function (event) {
      if (!event.target || !event.target.closest) return;
      if (!event.target.closest('variant-radios, variant-selects, .product-form__input')) return;
      // Defer so the theme can update the hidden input / URL first.
      setTimeout(function () {
        render(currentVariantId());
      }, 0);
    });

    root.dataset.vspecReady = 'true';
  }

  function boot() {
    document.querySelectorAll('[data-vspec-section]').forEach(initVariantSpecs);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  // Re-init when added/reloaded in the theme editor.
  document.addEventListener('shopify:section:load', function (event) {
    if (!event.target) return;
    var root = event.target.querySelector('[data-vspec-section]');
    if (root) initVariantSpecs(root);
  });
})();
{% endjavascript %}

{% stylesheet %}
.variant-specs {
  background-color: #eef4f5;
}

.variant-specs__eyebrow {
  display: flex;
  align-items: center;
  gap: 1.6rem;
  margin: 0 0 1.8rem;
  color: #a4231f;
  font-size: 1.3rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.variant-specs__eyebrow-line {
  display: inline-block;
  width: 4rem;
  height: 1px;
  background-color: #a4231f;
}

.variant-specs__heading {
  margin: 0 0 1.6rem;
  font-family: Georgia, "Times New Roman", Times, serif;
  font-size: 4.2rem;
  line-height: 1.05;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #121212;
}

.variant-specs__heading-accent {
  color: #a4231f;
}

.variant-specs__subheading {
  max-width: 60rem;
  margin: 0 0 4rem;
  font-size: 1.7rem;
  line-height: 1.5;
  color: #2b2b2b;
}

.variant-specs__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.6rem;
}

.vspec-card {
  background-color: #ffffff;
  border: 1px solid #e1e3e4;
  border-radius: 0.8rem;
  padding: 2.2rem 2.4rem;
}

.vspec-card__label {
  margin: 0 0 0.6rem;
  font-family: Georgia, "Times New Roman", Times, serif;
  font-size: 2.1rem;
  font-weight: 700;
  line-height: 1.2;
  color: #121212;
}

.vspec-card__value {
  margin: 0;
  font-size: 1.4rem;
  line-height: 1.4;
  color: #6b6b6b;
}

@media screen and (min-width: 750px) {
  .variant-specs__heading {
    font-size: 5.6rem;
  }

  .variant-specs__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
}

@media screen and (min-width: 990px) {
  .variant-specs__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Variant specs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What's inside"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Complete Snowboard"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent (red)",
      "default": "Specs"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Complete snowboard variants. Pre-tuned, waxed, and ready to ride."
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Variant specs"
    }
  ]
}
{% endschema %}
